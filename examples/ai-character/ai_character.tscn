[gd_scene load_steps=2 format=3 uid="uid://claw_aichar_main"]

[ext_resource type="Script" path="res://ai_character.gd" id="1_ai"]

; Root Control — fills the entire viewport.
[node name="AICharacter" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_ai")

; HBoxContainer splits the viewport: game world (left, expands) + chat panel (right, fixed ~310px).
[node name="HBoxContainer" type="HBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 0

; ── Game world pane (left, fills remaining space) ────────────────────────────

[node name="GamePane" type="Control" parent="HBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
clip_contents = true

; Dark green felt background fills the entire game pane.
[node name="GameBackground" type="ColorRect" parent="HBoxContainer/GamePane"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.1, 0.13, 0.1, 1.0)

; The character control is repositioned by the script in _ready() after layout.
; Initial size 48x48; offset_right/bottom encode the control size.
[node name="Character" type="Control" parent="HBoxContainer/GamePane"]
unique_name_in_owner = true
layout_mode = 1
offset_right = 48.0
offset_bottom = 48.0

; Blue square body — fills the 48x48 character control.
[node name="CharacterBody" type="ColorRect" parent="HBoxContainer/GamePane/Character"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.25, 0.45, 0.85, 1.0)

; Left eye (white square).
[node name="EyeLeft" type="ColorRect" parent="HBoxContainer/GamePane/Character"]
layout_mode = 1
offset_left = 8.0
offset_top = 12.0
offset_right = 18.0
offset_bottom = 22.0
color = Color(1.0, 1.0, 1.0, 1.0)

; Right eye (white square).
[node name="EyeRight" type="ColorRect" parent="HBoxContainer/GamePane/Character"]
layout_mode = 1
offset_left = 30.0
offset_top = 12.0
offset_right = 40.0
offset_bottom = 22.0
color = Color(1.0, 1.0, 1.0, 1.0)

; Speech bubble — shown above the character when AI uses the "speak" tool.
[node name="SpeechPanel" type="PanelContainer" parent="HBoxContainer/GamePane/Character"]
unique_name_in_owner = true
layout_mode = 1
offset_left = -64.0
offset_top = -60.0
offset_right = 112.0
offset_bottom = -12.0
visible = false

[node name="SpeechLabel" type="Label" parent="HBoxContainer/GamePane/Character/SpeechPanel"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(176.0, 44.0)
autowrap_mode = 3
text = ""

; Position indicator anchored to the bottom-left of the game pane.
[node name="CoordLabel" type="Label" parent="HBoxContainer/GamePane"]
unique_name_in_owner = true
layout_mode = 1
anchors_preset = 2
anchor_top = 1.0
anchor_bottom = 1.0
offset_left = 8.0
offset_top = -24.0
offset_right = 220.0
offset_bottom = 0.0
text = "Position: (0, 0)"
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.5, 0.7, 0.5, 0.8)

; Thin vertical separator between game world and chat panel.
[node name="VSeparator" type="VSeparator" parent="HBoxContainer"]
layout_mode = 2
size_flags_vertical = 3

; ── Chat panel (right, fixed ~310px) ─────────────────────────────────────────

[node name="ChatPanel" type="VBoxContainer" parent="HBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(310.0, 0.0)
size_flags_horizontal = 1
size_flags_vertical = 3
theme_override_constants/separation = 4

; Title row: label + settings button.
[node name="TitleRow" type="HBoxContainer" parent="HBoxContainer/ChatPanel"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="TitleLabel" type="Label" parent="HBoxContainer/ChatPanel/TitleRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "🤖  AI Character"
theme_override_font_sizes/font_size = 14

[node name="SettingsBtn" type="Button" parent="HBoxContainer/ChatPanel/TitleRow"]
unique_name_in_owner = true
layout_mode = 2
text = "⚙"
tooltip_text = "Open model and inference settings"

[node name="Sep0" type="HSeparator" parent="HBoxContainer/ChatPanel"]
layout_mode = 2

; Chat log — streaming AI output and tool-call events.
[node name="ChatLog" type="RichTextLabel" parent="HBoxContainer/ChatPanel"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
bbcode_enabled = true
scroll_following = true
selection_enabled = true

; One-line status: Generating…, Done., error text, etc.
[node name="StatusLabel" type="Label" parent="HBoxContainer/ChatPanel"]
unique_name_in_owner = true
layout_mode = 2
text = "Ready. Click ⚙ to load a model."
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.6, 0.6, 0.6, 1.0)
autowrap_mode = 3

; Prompt input row.
[node name="InputRow" type="HBoxContainer" parent="HBoxContainer/ChatPanel"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="PromptEdit" type="LineEdit" parent="HBoxContainer/ChatPanel/InputRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Tell the AI what to do…"

[node name="SendBtn" type="Button" parent="HBoxContainer/ChatPanel/InputRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Send"

[node name="StopBtn" type="Button" parent="HBoxContainer/ChatPanel/InputRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Stop"
tooltip_text = "Request the inference thread to stop early"

; ── Settings window (sub-window, hidden until ⚙ is pressed) ─────────────────

[node name="SettingsWindow" type="Window" parent="."]
unique_name_in_owner = true
title = "⚙  CLLawM Settings"
size = Vector2i(490, 560)
visible = false
transient = true
exclusive = true

[node name="MarginContainer" type="MarginContainer" parent="SettingsWindow"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="SettingsScroll" type="ScrollContainer" parent="SettingsWindow/MarginContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="SettingsBox" type="VBoxContainer" parent="SettingsWindow/MarginContainer/SettingsScroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="LblModel" type="Label" parent="SettingsWindow/MarginContainer/SettingsScroll/SettingsBox"]
layout_mode = 2
text = "Model path (.gguf)"

[node name="ModelRow" type="HBoxContainer" parent="SettingsWindow/MarginContainer/SettingsScroll/SettingsBox"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="ModelPathEdit" type="LineEdit" parent="SettingsWindow/MarginContainer/SettingsScroll/SettingsBox/ModelRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
