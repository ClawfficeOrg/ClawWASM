[node name="BrowseBtn" type="Button" parent="SettingsWindow/MarginContainer/SettingsScroll/SettingsBox/ModelRow"]
unique_name_in_owner = true
layout_mode = 2
text = "…"
tooltip_text = "Browse for a .gguf model file"

[node name="LblTemp" type="Label" parent="SettingsWindow/MarginContainer/SettingsScroll/SettingsBox"]
layout_mode = 2
text = "Temperature"
tooltip_text = "Sampling temperature (0 = deterministic, 2 = creative). Gemma 4 default: 1.0"

[node name="TempRow" type="HBoxContainer" parent="SettingsWindow/MarginContainer/SettingsScroll/SettingsBox"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="TempSlider" type="HSlider" parent="SettingsWindow/MarginContainer/SettingsScroll/SettingsBox/TempRow"]
unique_name_in_owner = true
